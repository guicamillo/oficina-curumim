---
import Layout from '../layouts/Layout.astro';
import Heart from '@lucide/astro/icons/heart';
import Target from '@lucide/astro/icons/target';
import Lightbulb from '@lucide/astro/icons/lightbulb';
import Calendar from '@lucide/astro/icons/calendar';
import ShieldCheck from '@lucide/astro/icons/shield-check';
import History from '@lucide/astro/icons/history';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import Users from '@lucide/astro/icons/users';
import Globe from '@lucide/astro/icons/globe';
import { withBase } from '../utils/paths';
import { getLangFromUrl, useTranslations } from '../utils/i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t({ key: 'about.meta.title', message: 'Sobre Nós - Oficina Curumim' })}>
    <main>
        {/* Hero Section */}
        <section class="relative pt-32 pb-20 px-4 overflow-hidden">
            <div class="max-w-7xl mx-auto text-center relative z-10">
                <h1 class="text-5xl md:text-8xl font-black text-slate-800 mb-6 tracking-tight">
                    {t({ key: 'about.hero.titlePrefix', message: 'Sobre' })} <span class="text-curumim-red ">{t({ key: 'about.hero.titleAccent', message: 'Nós' })}</span>
                </h1>
                <p class="text-xl md:text-2xl text-slate-600 font-medium max-w-3xl mx-auto leading-relaxed">
                    {t({ key: 'about.hero.subtitle', message: 'Unindo famílias brasileiras em Vancouver por meio da língua, da cultura e do afeto.' })}
                </p>
            </div>
            
            {/* Background elements */}
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1000px] h-[600px] bg-curumim-red/5 rounded-full blur-[120px] -z-10"></div>
        </section>

        {/* Mission Section */}
        <section class="py-24 px-4">
            <div class="max-w-7xl mx-auto">
                <div class="glass-card rounded-[3rem] p-8 md:p-16 border border-white/40 shadow-2xl relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-64 h-64 bg-curumim-red/5 rounded-full blur-3xl -z-10"></div>
                    <div class="grid grid-cols-1 lg:grid-cols-[40%_60%] gap-16 items-start">
                        <div class="space-y-6">
                            <div class="w-20 h-20 bg-curumim-red/10 rounded-3xl flex items-center justify-center">
                                <Target class="w-10 h-10 text-curumim-red" />
                            </div>
                            <h2 class="text-4xl md:text-6xl font-black text-slate-800">{t({ key: 'about.mission.titlePrefix', message: 'Nossa' })} <span class="text-curumim-red underline decoration-curumim-yellow/30 decoration-8 underline-offset-8">{t({ key: 'about.mission.titleAccent', message: 'Missão' })}</span></h2>
                            <p class="text-xl text-slate-500 font-medium italic leading-relaxed">
                                "{t({ key: 'about.mission.quote', message: 'Priorizamos que a criança seja feliz na Oficina Curumim.' })}"
                            </p>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            {[
                                { 
                                    text: t({ key: 'about.mission.cards.language', message: 'Estimular o desenvolvimento das habilidades orais, da leitura e da escrita em português.' }),
                                    icom: Heart,
                                    color: "text-curumim-red",
                                    bg: "bg-curumim-red/5"
                                },
                                { 
                                    text: t({ key: 'about.mission.cards.memory', message: 'Proporcionar memória afetiva positiva em relação ao português, respeitando o ritmo de cada criança.' }),
                                    icom: Lightbulb,
                                    color: "text-curumim-yellow",
                                    bg: "bg-curumim-yellow/5"
                                },
                                { 
                                    text: t({ key: 'about.mission.cards.belonging', message: 'Ampliar o vocabulário e trazer a noção de pertencimento às origens brasileiras.' }),
                                    icom: Users,
                                    color: "text-curumim-green",
                                    bg: "bg-curumim-green/5"
                                },
                                { 
                                    text: t({ key: 'about.mission.cards.identity', message: 'Estreitar a relação entre língua, identidade e cultura brasileira no Canadá.' }),
                                    icom: Globe,
                                    color: "text-curumim-cyan",
                                    bg: "bg-curumim-cyan/5"
                                }
                            ].map((item) => (
                                <div class="glass-card p-8 rounded-3xl border border-white/60 shadow-sm hover:shadow-md transition-all group">
                                    <div class={`w-12 h-12 ${item.bg} rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform`}>
                                        <item.icom class={`w-6 h-6 ${item.color}`} />
                                    </div>
                                    <p class="text-slate-700 font-bold leading-relaxed">{item.text}</p>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {/* Pedagogical Approach */}
        <section class="py-24 px-4">
            <div class="max-w-5xl mx-auto">
                <div class="text-center space-y-8">
                    
                    <h2 class="text-4xl md:text-6xl font-black text-slate-800">{t({ key: 'about.pedagogy.titlePrefix', message: 'Proposta' })} <span class="text-curumim-green">{t({ key: 'about.pedagogy.titleAccent', message: 'pedagógica' })}</span></h2>
                    <div class="glass-card p-10 md:p-16 rounded-[3rem] border border-white/60 shadow-xl relative">
                        <div class="absolute -top-12 -left-12 w-24 h-24 bg-curumim-yellow rounded-[2rem] -z-10 rotate-12 opacity-20"></div>
                        <p class="text-xl md:text-2xl text-slate-600 leading-relaxed font-medium">
                            {t({ key: 'about.pedagogy.body', message: 'Em um ambiente lúdico e participativo, as crianças desenvolvem atividades relacionadas às manifestações folclóricas, personalidades, fatos, arte, literatura e histórias brasileiras. As propostas das atividades são pautadas a partir de um tema de estudo.' })}
                        </p>
                    </div>
                </div>
            </div>
        </section>

        {/* Academic Year & Conduct */}
        <section class="py-24 px-4">
            <div class="max-w-7xl mx-auto">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="glass-card p-12 rounded-[3rem] border border-white/50 shadow-xl space-y-6 relative overflow-hidden group">
                        <div class="absolute -top-10 -right-10 w-40 h-40 bg-curumim-orange/5 rounded-full blur-3xl"></div>
                        <div class="w-16 h-16 bg-curumim-orange/10 rounded-2xl flex items-center justify-center">
                            <Calendar class="w-8 h-8 text-curumim-orange" />
                        </div>
                        <h2 class="text-3xl font-black text-slate-800">{t({ key: 'about.academicYear.title', message: 'Ano letivo' })}</h2>
                        <p class="text-lg text-slate-600 font-medium leading-relaxed">
                            {t({ key: 'about.academicYear.body', message: 'As aulas acontecem durante três períodos ao longo do ano:' })} 
                            <span class="block mt-4 text-slate-800 font-bold">• {t({ key: 'about.academicYear.periodOne', message: 'Janeiro a Março' })}</span>
                            <span class="block text-slate-800 font-bold">• {t({ key: 'about.academicYear.periodTwo', message: 'Abril a Junho' })}</span>
                            <span class="block text-slate-800 font-bold">• {t({ key: 'about.academicYear.periodThree', message: 'Setembro a Dezembro' })}</span>
                        </p>
                    </div>

                    <div class="glass-card p-12 rounded-[3rem] border border-white/50 shadow-xl space-y-6 relative overflow-hidden group">
                        <div class="absolute -top-10 -right-10 w-40 h-40 bg-curumim-cyan/5 rounded-full blur-3xl"></div>
                        <div class="w-16 h-16 bg-curumim-cyan/10 rounded-2xl flex items-center justify-center">
                            <ShieldCheck class="w-8 h-8 text-curumim-cyan" />
                        </div>
                        <h2 class="text-3xl font-black text-slate-800">{t({ key: 'about.conduct.title', message: 'Código de Conduta' })}</h2>
                        <p class="text-lg text-slate-600 font-medium leading-relaxed">
                            {t({ key: 'about.conduct.body', message: 'Para manter um ambiente organizado e seguro para todos, é essencial que pais e alunos sigam nosso guia de conduta.' })}
                        </p>
                        <div class="pt-4">
                            <a href="https://docs.google.com/document/d/1pJRK8tmHNGRAkDkY8gr9YphOaSDKs6p52fDPXJZNrOk/edit?usp=sharing" target="_blank" rel="noopener noreferrer" 
                               class="inline-flex items-center gap-2 px-6 py-3 bg-slate-900 text-white font-bold rounded-xl hover:bg-curumim-cyan transition-all">
                                {t({ key: 'about.conduct.cta', message: 'Acessar o guia' })}
                                <ArrowRight class="w-4 h-4" />
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {/* History Timeline */}
        <section class="py-24 px-4 relative overflow-hidden">
             <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-b from-transparent via-curumim-yellow/5 to-transparent -z-10"></div>
            <div class="max-w-4xl mx-auto">
                <div class="text-center mb-16 space-y-4">
                    <div class="w-20 h-20 bg-white glass-card rounded-3xl flex items-center justify-center mx-auto mb-6 shadow-lg">
                        <History class="w-10 h-10 text-curumim-orange" />
                    </div>
                    <h2 class="text-4xl md:text-6xl font-black text-slate-800">{t({ key: 'about.history.titlePrefix', message: 'Nossa' })} <span class="text-curumim-orange">{t({ key: 'about.history.titleAccent', message: 'História' })}</span></h2>
                </div>

                <div class="space-y-12 relative">
                    <div class="absolute left-[2.5rem] top-0 bottom-0 w-1 bg-gradient-to-b from-curumim-yellow via-curumim-red to-curumim-purple opacity-20 hidden md:block"></div>
                    
                    {[
                        { 
                            year: "2012", 
                            title: t({ key: 'about.history.timeline.2012.title', message: 'Outubro de 2012' }), 
                            text: t({ key: 'about.history.timeline.2012.body', message: 'Um grupo de famílias se une para desenvolver atividades educativas, em português, com seus filhos.' }),
                            color: "bg-curumim-yellow",
                            icomColor: "text-curumim-yellow"
                        },
                        { 
                            year: "2013", 
                            title: t({ key: 'about.history.timeline.2013.title', message: 'Março de 2013' }), 
                            text: t({ key: 'about.history.timeline.2013.body', message: "A Oficina Curumim é registrada como uma organização sem fins lucrativos, 'Oficina Curumim Parents Society'." }),
                            color: "bg-curumim-green",
                            icomColor: "text-curumim-green"
                        }
                    ].map((item) => (
                        <div class="flex flex-col md:flex-row gap-8 relative z-10">
                            <div class="flex-shrink-0">
                                <div class={`w-20 h-20 ${item.color} rounded-3xl flex items-center justify-center shadow-lg transform hover:rotate-12 transition-transform`}>
                                    <span class="text-xl font-black text-slate-900">{item.year}</span>
                                </div>
                            </div>
                            <div class="glass-card flex-1 p-8 rounded-3xl border border-white/60 shadow-lg">
                                <h3 class="text-2xl font-black text-slate-800 mb-2">{item.title}</h3>
                                <p class="text-lg text-slate-600 font-medium leading-relaxed">
                                    {item.text}
                                </p>
                            </div>
                        </div>
                    ))}

                    <div class="bg-gradient-to-br from-slate-900 to-slate-800 rounded-[3rem] p-10 md:p-16 text-center relative overflow-hidden group">
                        <div class="absolute inset-0 bg-gradient-to-tr from-curumim-red/20 via-transparent to-curumim-yellow/20 opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                        <p class="text-2xl md:text-4xl font-black text-white leading-tight relative z-10">
                            {t({ key: 'about.history.highlight.prefix', message: 'Hoje, mais de 10 anos depois, contamos com' })} <span class="text-curumim-yellow underline decoration-4 underline-offset-8">{t({ key: 'about.history.highlight.emphasis', message: 'mais de 100 crianças' })}</span> {t({ key: 'about.history.highlight.suffix', message: 'crescendo com orgulho de suas raízes brasileiras.' })}
                        </p>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>
