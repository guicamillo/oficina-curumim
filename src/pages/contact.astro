---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---
<Layout title="Contato - Oficina Curumim">
    <Header />
    <main class="bg-slate-50">
        {/* Hero Section */}
        <section class="bg-gradient-to-br from-blue-600 to-green-600 py-20">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Contato</h1>
                <p class="text-xl text-blue-50">Diga oi! Adoraríamos ouvir de você.</p>
            </div>
        </section>

        {/* Contact Info */}
        <section class="py-20">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                    {/* Left Column - Contact Info */}
                    <div class="lg:col-span-1 space-y-6">
                        {/* Email */}
                        <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-100">
                            <div class="flex items-start gap-4">
                                <div class="flex-shrink-0 w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center text-xl">
                                    ✉️
                                </div>
                                <div class="min-w-0">
                                    <h3 class="text-lg font-bold text-slate-900 mb-1">E-mail</h3>
                                    <a href="mailto:oficinacurumim@gmail.com" class="text-base text-blue-600 hover:text-blue-700 hover:underline break-all">
                                        oficinacurumim@gmail.com
                                    </a>
                                </div>
                            </div>
                        </div>

                        {/* Location */}
                        <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-100">
                            <div class="flex items-start gap-4">
                                <div class="flex-shrink-0 w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center text-xl">
                                    📍
                                </div>
                                <div>
                                    <h3 class="text-lg font-bold text-slate-900 mb-1">Localização das aulas</h3>
                                    <p class="text-base text-slate-700 font-medium mb-1">Mount Pleasant Neighbourhood House</p>
                                    <a href="https://www.google.com/maps/place/Mount+Pleasant+Neighbourhood+House/@49.2623148,-123.0891644,17z" target="_blank" rel="noopener noreferrer" class="text-sm text-blue-600 hover:text-blue-700 hover:underline">
                                        800 E Broadway, Vancouver, BC V5T 1Y1
                                    </a>
                                </div>
                            </div>
                        </div>

                        {/* Mailing Address */}
                        <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-100">
                            <div class="flex items-start gap-4">
                                <div class="flex-shrink-0 w-10 h-10 bg-purple-100 rounded-xl flex items-center justify-center text-xl">
                                    📮
                                </div>
                                <div>
                                    <h3 class="text-lg font-bold text-slate-900 mb-1">Endereço para correspondência</h3>
                                    <p class="text-base text-slate-700">
                                        PO Box 78030 Grandview PO<br/>
                                        Vancouver BC V5N 5W1
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    {/* Right Column - Contact Form */}
                    <div class="lg:col-span-2">
                        <div class="bg-white rounded-2xl shadow-lg p-8 md:p-12 border border-slate-100 h-full">
                            <h2 class="text-2xl font-bold text-slate-900 mb-6">Envie uma mensagem</h2>
                            <form class="space-y-6">
                                <div>
                                    <label for="name" class="block text-sm font-medium text-slate-700 mb-2">Nome</label>
                                    <input type="text" id="name" name="name" class="block w-full rounded-lg border-slate-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-lg p-3 border" />
                                </div>
                                <div>
                                    <label for="email" class="block text-sm font-medium text-slate-700 mb-2">Email</label>
                                    <input type="email" id="email" name="email" class="block w-full rounded-lg border-slate-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-lg p-3 border" />
                                </div>
                                <div>
                                    <label for="message" class="block text-sm font-medium text-slate-700 mb-2">Mensagem</label>
                                    <textarea id="message" name="message" rows="5" class="block w-full rounded-lg border-slate-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-lg p-3 border"></textarea>
                                </div>
                                <button type="submit" class="w-full inline-flex justify-center py-3 px-6 border border-transparent shadow-sm text-lg font-medium rounded-full text-white bg-gradient-to-r from-blue-600 to-green-600 hover:from-blue-700 hover:to-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all">
                                    Enviar
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>
