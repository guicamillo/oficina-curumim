---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ id }) => id.startsWith('pt-BR/'));
  return posts.map(post => ({
    params: { slug: post.id.replace('pt-BR/', '').replace('.md', '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} - Oficina Curumim`}>
  <Header />
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <article class="prose prose-slate lg:prose-lg mx-auto">
        <header class="mb-8 not-prose">
            <div class="flex items-center gap-2 text-sm text-slate-500 mb-4">
                <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('pt-BR', { dateStyle: 'long' })}
                </time>
                <span>•</span>
                <span>{post.data.author}</span>
            </div>
            <h1 class="text-4xl font-bold text-slate-900 mb-4">{post.data.title}</h1>
            {post.data.image && (
                <img src={post.data.image} alt={post.data.title} class="w-full h-64 sm:h-96 object-cover rounded-2xl shadow-sm" />
            )}
        </header>
        <div class="mt-8">
            <Content />
        </div>
    </article>
  </main>
</Layout>
