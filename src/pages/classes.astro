---
import Layout from '../layouts/Layout.astro';
import Sparkles from '@lucide/astro/icons/sparkles';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import { getLangFromUrl, useTranslations } from '../utils/i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const turmas = [
    {
        id: "0",
        name: t({ key: 'classes.groups.tatuzinhos.name', message: 'TATUZINHOS' }),
        range: [t({ key: 'classes.groups.tatuzinhos.moduleOne', message: 'Módulo 1: 6-18 meses' }), t({ key: 'classes.groups.tatuzinhos.moduleTwo', message: 'Módulo 2: 19-30 meses' })],
        description: t({ key: 'classes.groups.tatuzinhos.description', message: 'Propostas envolvendo a oralidade, músicas, contação e leitura de histórias, esquema corporal, brincadeiras, sons e diferentes estímulos (visual, tátil, auditivo, motor).' }),
        color: "curumim-yellow",
        blobColor: "bg-curumim-yellow"
    },
    {
        id: "1",
        name: t({ key: 'classes.groups.oncinhas.name', message: 'ONCINHAS' }),
        range: [t({ key: 'classes.groups.oncinhas.range', message: '2,5 a 4 anos (aproximadamente)' })],
        description: t({ key: 'classes.groups.oncinhas.description', message: 'Propostas envolvendo a oralidade, músicas, contação e leitura de histórias, esquema corporal, brincadeiras brasileiras e estímulo para falar português.' }),
        color: "curumim-green",
        blobColor: "bg-curumim-green"
    },
    {
        id: "2",
        name: t({ key: 'classes.groups.macaquinhos.name', message: 'MACAQUINHOS' }),
        range: [t({ key: 'classes.groups.macaquinhos.range', message: '4 a 6 anos (aprox.)' })],
        description: t({ key: 'classes.groups.macaquinhos.description', message: 'Propostas envolvendo a introdução de práticas de leitura e escrita, músicas, parlendas, contação e leitura de histórias, esquema corporal, rimas, jogos, dramatizações e leitura de imagens.' }),
        color: "curumim-orange",
        blobColor: "bg-curumim-orange"
    },
    {
        id: "3",
        name: t({ key: 'classes.groups.indiozinhos.name', message: 'INDIOZINHOS' }),
        range: [t({ key: 'classes.groups.indiozinhos.range', message: '6 a 8 anos (aprox.)' })],
        description: t({ key: 'classes.groups.indiozinhos.description', message: 'Propostas que aproximam a criança da leitura e escrita, por meio da música, de pequenos textos, da contação e leitura de histórias, de jogos, brincadeiras, dramatizações e da produção de pequenos textos escritos.' }),
        color: "curumim-purple",
        blobColor: "bg-curumim-purple"
    },
    {
        id: "4",
        name: t({ key: 'classes.groups.tucanos.name', message: 'TUCANOS' }),
        range: [t({ key: 'classes.groups.tucanos.range', message: '8 a 12 anos (aprox.)' })],
        description: t({ key: 'classes.groups.tucanos.description', message: 'Propostas envolvendo a compreensão da estrutura e o funcionamento básico da língua, utilizando-as em situações de comunicação oral, de leitura e de escrita. Produção formal através de diversos gêneros textuais.' }),
        color: "curumim-red",
        blobColor: "bg-curumim-red"
    }
];

const colorMap = {
    'curumim-yellow': {
        text: 'text-curumim-yellow',
        from: 'from-curumim-yellow',
        gradient: 'from-curumim-yellow/10',
        blob: 'bg-curumim-yellow',
        border: 'border-curumim-yellow/20'
    },
    'curumim-green': {
        text: 'text-curumim-green',
        from: 'from-curumim-green',
        gradient: 'from-curumim-green/10',
        blob: 'bg-curumim-green',
        border: 'border-curumim-green/20'
    },
    'curumim-orange': {
        text: 'text-curumim-orange',
        from: 'from-curumim-orange',
        gradient: 'from-curumim-orange/10',
        blob: 'bg-curumim-orange',
        border: 'border-curumim-orange/20'
    },
    'curumim-purple': {
        text: 'text-curumim-purple',
        from: 'from-curumim-purple',
        gradient: 'from-curumim-purple/10',
        blob: 'bg-curumim-purple',
        border: 'border-curumim-purple/20'
    },
    'curumim-red': {
        text: 'text-curumim-red',
        from: 'from-curumim-red',
        gradient: 'from-curumim-red/10',
        blob: 'bg-curumim-red',
        border: 'border-curumim-red/20'
    }
};

const base = import.meta.env.BASE_URL;
---

<Layout title={t({ key: 'classes.meta.title', message: 'Nossas Turmas - Oficina Curumim' })}>
    <main>
        {/* Hero Section */}
        <section class="relative pt-32 pb-20 px-4 overflow-hidden">
            <div class="max-w-7xl mx-auto text-center relative z-10">
                <h1 class="text-5xl md:text-8xl font-black text-slate-800 mb-8 tracking-tight">
                    {t({ key: 'classes.hero.titlePrefix', message: 'Nossas' })} <span class="text-curumim-cyan ">{t({ key: 'classes.hero.titleAccent', message: 'Turmas' })}</span>
                </h1>
                <p class="text-xl md:text-2xl text-slate-600 font-medium max-w-4xl mx-auto leading-relaxed">
                    {t({ key: 'classes.hero.subtitle', message: 'Cada fase é única. Dividimos nossas turmas para explorar ao máximo o potencial de cada etapa, sempre respeitando o tempo individual de desenvolvimento de cada criança.' })}
                </p>
            </div>
            
            {/* Background elements */}
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1000px] h-[600px] bg-curumim-cyan/5 rounded-full blur-[120px] -z-10"></div>
        </section>

        {/* Turmas List */}
        <section class="py-12 px-4 space-y-32 pb-32">
            {turmas.map((turma, index) => {
                const colors = colorMap[turma.color];
                return (
                    <div class="max-w-7xl mx-auto">
                        <div class={`grid grid-cols-1 lg:grid-cols-2 gap-16 items-center ${index % 2 !== 0 ? 'lg:flex-row-reverse' : ''}`}>
                            {/* Visual Side */}
                            <div class={`${index % 2 !== 0 ? 'lg:order-2' : ''}`}>
                                <div class="relative group">
                                    <div class={`absolute -top-12 -left-12 w-24 h-24 ${colors.blob} rounded-[2rem] -z-10 rotate-12 opacity-10`}></div>
                                    <div class={`absolute -inset-4 bg-gradient-to-tr ${colors.gradient} to-transparent rounded-[3rem] blur-2xl opacity-0 group-hover:opacity-100 transition duration-700`}></div>
                                    <div class="relative aspect-video lg:aspect-square glass-card rounded-[3rem] border border-white/60 overflow-hidden shadow-2xl flex items-center justify-center p-12">
                                        <img src={`${base}logo.svg`} alt="" class="w-1/2 opacity-10 group-hover:scale-110 transition duration-1000" />
                                        <div class={`absolute inset-0 bg-gradient-to-br ${colors.gradient} to-transparent`}></div>
                                    </div>
                                </div>
                            </div>

                            {/* Text Side */}
                            <div class={`space-y-8 relative ${index % 2 !== 0 ? 'lg:order-1' : ''}`}>
                                <div class="space-y-4">
                                    <div class="flex items-center gap-4">
                                        <span class={`text-6xl font-black opacity-40 ${colors.text}`}>0{turma.id}</span>
                                        <div class={`h-1.5 flex-1 bg-gradient-to-r ${colors.from} to-transparent rounded-full opacity-60`}></div>
                                    </div>
                                    <h2 class={`text-4xl md:text-6xl font-black text-slate-800`}>
                                        {turma.name}
                                    </h2>
                                    <div class="flex flex-wrap gap-3">
                                        {turma.range.map(r => (
                                            <span class={`px-4 py-2 bg-white/40 text-slate-700 font-bold rounded-xl text-sm border ${colors.border}`}>
                                                {r}
                                            </span>
                                        ))}
                                    </div>
                                </div>

                                <div class="glass-card p-8 md:p-10 rounded-3xl border border-white/60 shadow-xl relative overflow-hidden group">
                                    <p class="text-xl text-slate-600 leading-relaxed font-medium">
                                        {turma.description}
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                );
            })}
        </section>

        {/* Final CTA */}
        <section class="py-32 px-4 relative overflow-hidden">
            <div class="max-w-5xl mx-auto">
                <div class="bg-gradient-to-br from-slate-900 to-slate-800 rounded-[4rem] p-12 md:p-24 text-center space-y-10 relative shadow-2xl group overflow-hidden">
                    <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-tr from-curumim-cyan/20 via-transparent to-curumim-green/20 opacity-0 group-hover:opacity-100 transition-opacity duration-1000"></div>
                    
                    <div class="space-y-6 relative z-10">
                        <p class="text-curumim-yellow font-black text-xl uppercase tracking-widest">{t({ key: 'classes.cta.badge', message: '- Vem pra Oficina -' })}</p>
                        <h2 class="text-4xl md:text-7xl font-black text-white leading-tight">
                            {t({ key: 'classes.cta.title', message: 'Cadastre seu Curumim hoje mesmo!' })}
                        </h2>
                        <p class="text-slate-400 text-lg md:text-xl max-w-2xl mx-auto font-medium">
                            {t({ key: 'classes.cta.body', message: 'Junte-se à nossa comunidade e proporcione uma conexão profunda com as raízes brasileiras.' })}
                        </p>
                    </div>

                    <div class="pt-8 relative z-10">
                        <a href={`${base}contact`} class="inline-flex items-center gap-4 px-12 py-6 bg-curumim-yellow hover:bg-curumim-orange text-slate-900 font-black text-2xl rounded-[2rem] transition-all hover:scale-110 active:scale-95 shadow-2xl shadow-curumim-yellow/20">
                            {t({ key: 'classes.cta.button', message: 'Falar com a gente' })}
                            <ArrowRight class="w-8 h-8" />
                        </a>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>
