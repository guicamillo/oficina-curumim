---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import { useTranslations } from '../utils/i18n';

const t = useTranslations('pt-BR');
---

<Layout title="Oficina Curumim - Português e Cultura Brasileira">
	<Header />
	<main>
		{/* Hero Section with Colorful Background */}
		{/* Hero Section with Image Background */}
		<section class="relative overflow-hidden min-h-[85vh] flex items-center">
            {/* Background Image with Overlay */}
            <div class="absolute inset-0 z-0">
                <img src="/hero.jpg" alt="Background" class="w-full h-full object-cover" />
                <div class="absolute inset-0 bg-gradient-to-r from-slate-900/90 via-slate-900/60 to-transparent"></div>
            </div>

            {/* Decorative circles */}
            <div class="absolute top-20 left-10 w-32 h-32 bg-[#ea1f4b] rounded-full opacity-20 blur-2xl z-10"></div>
            <div class="absolute bottom-20 right-10 w-40 h-40 bg-[#ed8300] rounded-full opacity-20 blur-2xl z-10"></div>
            
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
                <div class="grid grid-cols-1 lg:grid-cols-[70%_30%] gap-12 items-center">
                    {/* Content Column */}
                    <div class="text-left">
                        <div class="bg-white/10 backdrop-blur-md rounded-3xl p-6 md:p-10 shadow-xl border border-white/20">
                            <h1 class="text-3xl md:text-5xl font-black text-white mb-4 leading-tight drop-shadow-lg">
                                No coração de Vancouver.
                            </h1>
                            <h2 class="text-2xl md:text-4xl font-black text-white mb-8">
                                E com o <span class="drop-shadow-md" style="background: linear-gradient(to right, #009639, #FFD700); -webkit-background-clip: text; color: transparent;">BRASIL</span> no coração.
                            </h2>
                        </div>
                    </div>
                    {/* Right column intentionally left empty to show background image */}
                    <div></div>
                </div>
			</div>
		</section>
        
        {/* Quem somos Section - Image Placeholder Style */}
        <section class="py-20 bg-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid grid-cols-1 lg:grid-cols-[30%_70%] gap-12 items-center max-w-6xl mx-auto">
                    {/* Image Placeholder */}
                    <div class="relative">
                        <div class="aspect-square bg-gradient-to-br from-white to-gray-400 rounded-3xl shadow-2xl transform hover:scale-105 transition-transform duration-500"></div>
                        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent rounded-3xl"></div>
                    </div>

                    {/* Content */}
                    <div class="space-y-6">
                        <h2 class="text-4xl md:text-5xl font-black text-[#ea1f4b]">
                            Quem somos
                        </h2>
                        <p class="text-xl text-slate-700 leading-relaxed">
                            Oficina Curumim é uma organização sem fins lucrativos com a missão de estimular o uso da Língua Portuguesa oral e escrita, bem como valorizar o contato com a cultura brasileira para famílias brasileiras da grande Vancouver. Os aspectos culturais, artísticos e sociais da cultura brasileira são utilizados como contexto para o desenvolvimento das propostas nas turmas.
                        </p>
                        <div>
                            <a href="/about" class="inline-block px-8 py-3 bg-[#ea1f4b] text-white font-black text-lg rounded-full hover:bg-[#8a00aa] transition-colors duration-300">
                                Saiba mais →
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {/* Nossas turmas Preview - Clean Style */}
        <section class="py-20 bg-slate-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-12">
                    <h2 class="text-4xl md:text-5xl font-black text-[#2ccdff] mb-6">
                        Nossas turmas
                    </h2>
                    <p class="text-xl text-slate-700 leading-relaxed max-w-3xl mx-auto mb-8">
                        Temos turmas de crianças a partir de 6 meses até 12 anos de idade. Conheça as atividades e propostas de cada uma.
                    </p>
                    <a href="/classes" class="inline-block px-8 py-3 bg-[#2ccdff] text-white font-black text-lg rounded-full hover:bg-[#32bf6e] transition-colors duration-300">
                        Saiba mais →
                    </a>
                </div>
            </div>
        </section>

		{/* Schedule & Location - Image Placeholder Style */}
		<section class="py-20 bg-slate-50">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-6xl mx-auto">
					<div class="flex flex-col md:flex-row gap-8 items-center">
						{/* Image Placeholder */}
						<div class="relative flex-shrink-0">
							<div class="w-48 h-48 bg-gradient-to-br from-white to-gray-400 rounded-3xl shadow-2xl transform hover:scale-105 transition-transform duration-500"></div>
							<div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent rounded-3xl"></div>
						</div>

						{/* Content */}
						<div class="space-y-4">
							<h2 class="text-3xl font-black text-[#ea1f4b]">Horário</h2>
							<p class="text-xl text-slate-700 font-bold">
								Domingos das 10:00am às 12:00pm
							</p>
							<p class="text-slate-600 text-sm">
								(Não há aula em finais de semana prolongados dos feriados canadenses)
							</p>
						</div>
					</div>

					<div class="flex flex-col md:flex-row gap-8 items-center">
						{/* Image Placeholder */}
						<div class="relative flex-shrink-0">
							<div class="w-48 h-48 bg-gradient-to-br from-white to-gray-400 rounded-3xl shadow-2xl transform hover:scale-105 transition-transform duration-500"></div>
							<div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent rounded-3xl"></div>
						</div>

						{/* Content */}
						<div class="space-y-4">
							<h2 class="text-3xl font-black text-[#32bf6e]">Localização</h2>
							<p class="text-lg font-bold text-slate-700">Mount Pleasant Neighbourhood House</p>
							<a href="https://www.google.com/maps/place/Mount+Pleasant+Neighbourhood+House/@49.2623148,-123.0891644,17z" target="_blank" rel="noopener noreferrer" class="inline-block text-lg text-[#2ccdff] hover:text-[#32bf6e] underline font-semibold transition-colors">
								800 E Broadway, Vancouver, BC V5T 1Y1
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		{/* Library Section - Image Placeholder Style */}
		<section class="py-20 bg-white">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid grid-cols-1 lg:grid-cols-[70%_30%] gap-12 items-center max-w-6xl mx-auto">
					{/* Content */}
					<div class="space-y-6">
						<h2 class="text-4xl md:text-5xl font-black text-[#8a00aa]">
							Nossa biblioteca
						</h2>
						<p class="text-lg text-slate-700 leading-relaxed">
							As famílias são voluntárias para a organização, catalogação, empréstimos e conferência do acervo. A criança é incentivada a escolher um livro por semana e fazer a leitura com a família em casa. As famílias também podem escolher um título.
						</p>
						<p class="text-lg text-slate-700 leading-relaxed">
							A leitura de livros, em português, é importante para a manutenção e estímulo do idioma.
						</p>
						<div class="bg-gradient-to-r from-[#fbcd00] to-[#ed8300] rounded-2xl p-6 shadow-lg inline-block">
							<p class="text-2xl md:text-3xl font-black text-white text-center">
								+ de 1000 títulos infantis!
							</p>
						</div>
					</div>

					{/* Image Placeholder */}
					<div class="relative">
						<div class="aspect-square bg-gradient-to-br from-white to-gray-400 rounded-3xl shadow-2xl transform hover:scale-105 transition-transform duration-500"></div>
						<div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent rounded-3xl"></div>
					</div>
				</div>
			</div>
		</section>

        {/* Eventos culturais Preview - Image Placeholder Style */}
        <section class="py-20 bg-slate-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid grid-cols-1 lg:grid-cols-[30%_70%] gap-12 items-center max-w-6xl mx-auto">
                    {/* Image Placeholder */}
                    <div class="relative">
                        <div class="aspect-square bg-gradient-to-br from-white to-gray-400 rounded-3xl shadow-2xl transform hover:scale-105 transition-transform duration-500"></div>
                        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent rounded-3xl"></div>
                    </div>

                    {/* Content */}
                    <div class="space-y-6">
                        <h2 class="text-4xl md:text-5xl font-black text-[#ea1f4b]">
                            Eventos culturais
                        </h2>
                        <p class="text-xl text-slate-700 leading-relaxed">
                            Temos eventos culturais durante o ano todo na Oficina Curumim. Confira nosso calendário anual e não fique fora de nenhum deles.
                        </p>
                        <div>
                            <a href="/events" class="inline-block px-8 py-3 bg-[#ea1f4b] text-white font-black text-lg rounded-full hover:bg-[#8a00aa] transition-colors duration-300">
                                Calendário anual →
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {/* Quer trabalhar conosco - Image Placeholder Style */}
        <section class="py-20 bg-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid grid-cols-1 lg:grid-cols-[70%_30%] gap-12 items-center max-w-6xl mx-auto">
                    {/* Content */}
                    <div class="space-y-6">
                        <h2 class="text-4xl md:text-5xl font-black text-[#32bf6e]">
                            Quer trabalhar conosco?
                        </h2>
                        <p class="text-xl text-slate-700 leading-relaxed">
                            Estamos sempre buscando voluntários e parceiros. Clique e saiba como fazer parte da nossa equipe.
                        </p>
                        <div>
                            <a href="/jobs" class="inline-block px-8 py-3 bg-[#32bf6e] text-white font-black text-lg rounded-full hover:bg-[#2ccdff] transition-colors duration-300">
                                Trabalhe com a gente →
                            </a>
                        </div>
                    </div>

                    {/* Image Placeholder */}
                    <div class="relative">
                        <div class="aspect-square bg-gradient-to-br from-white to-gray-400 rounded-3xl shadow-2xl transform hover:scale-105 transition-transform duration-500"></div>
                        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent rounded-3xl"></div>
                    </div>
                </div>
            </div>
        </section>
	</main>


</Layout>
