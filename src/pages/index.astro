---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../utils/i18n';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import Calendar from '@lucide/astro/icons/calendar';
import MapPin from '@lucide/astro/icons/map-pin';
import BookOpen from '@lucide/astro/icons/book-open';
import Heart from '@lucide/astro/icons/heart';
import Users from '@lucide/astro/icons/users';
import backgroundSvg from '../assets/background.svg';
import bibliotecaImg1 from '../assets/img/biblioteca_1.jpeg';
import bibliotecaImg2 from '../assets/img/biblioteca_2.jpeg';
import bibliotecaImg3 from '../assets/img/biblioteca_3.jpeg';
import heroImg2 from '../assets/img/hero_2.jpeg';
import heroImg3 from '../assets/img/hero_3.jpeg';
import { Image } from 'astro:assets';
import { withBase } from '../utils/paths';

const t = useTranslations('pt-BR');

const bibliotecaImages = [bibliotecaImg1, bibliotecaImg2, bibliotecaImg3];
const randomBibliotecaImg = bibliotecaImages[Math.floor(Math.random() * bibliotecaImages.length)];

const heroImages = [heroImg2, heroImg3];
const randomHeroImg = heroImages[Math.floor(Math.random() * heroImages.length)];
---

<Layout title="Oficina Curumim - Português e Cultura Brasileira">
	<main>
		{/* Hero Section */}
		<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
             {/* Background Image */}
            <div class="absolute inset-0 z-0">
                <Image src={randomHeroImg} alt="Background" class="w-full h-full object-cover" loading="eager" />
                <div class="absolute inset-0 bg-gradient-to-r from-slate-900/90 via-slate-900/70 to-slate-900/30"></div>
            </div>

            {/* Decorative Overlay */}
            <div class="absolute inset-0 z-0 opacity-10 bg-cover mix-blend-overlay" style={`background-image: url(${backgroundSvg.src})`}></div>

			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full pt-20">
                <div class="max-w-3xl">
                    <h1 class="text-5xl md:text-7xl lg:text-8xl font-black text-white leading-tight mb-8 drop-shadow-lg">
                        No coração de <span class="text-curumim-red">Vancouver</span>.
                    </h1>
                    <h2 class="text-2xl md:text-4xl font-bold text-slate-200 leading-relaxed mb-10 max-w-2xl">
                        E com o <span class="bg-gradient-to-r from-curumim-green to-curumim-yellow bg-clip-text text-transparent font-black">BRASIL</span> no coração.
                    </h2>
                    
                    <div class="flex flex-col sm:flex-row gap-4">
                        <a href={withBase('about')} class="px-8 py-4 bg-curumim-yellow hover:bg-curumim-orange text-slate-900 font-black rounded-2xl transition-all hover:scale-[1.05] active:scale-95 shadow-lg shadow-curumim-yellow/20 flex items-center justify-center gap-2 text-lg">
                            Conheça nossa história
                            <ArrowRight class="w-5 h-5" />
                        </a>
                        <a href={withBase('classes')} class="px-8 py-4 bg-white/10 hover:bg-white/20 backdrop-blur-md text-white font-bold rounded-2xl transition-all hover:scale-[1.05] active:scale-95 border border-white/30 flex items-center justify-center gap-2 text-lg">
                            Nossas Turmas
                        </a>
                    </div>
                </div>
			</div>
		</section>
        
        {/* Quem somos Section */}
        <section class="py-24 relative overflow-hidden">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="glass-card rounded-[3rem] p-8 md:p-16 shadow-xl border border-white/40">
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                        <div class="relative order-2 lg:order-1">
                             <div class="aspect-square glass-card rounded-[2rem] flex items-center justify-center p-4 relative overflow-hidden">
                                 <div class="absolute inset-0 bg-gradient-to-br from-curumim-red/5 to-curumim-purple/5"></div>
                                 <Heart class="w-32 h-32 text-curumim-red/20 absolute -top-8 -right-8 rotate-12" />
                                 <Users class="w-64 h-64 text-slate-200" />
                                 <div class="absolute inset-0 flex items-center justify-center">
                                     <span class="text-slate-400 font-black text-xl uppercase tracking-widest opacity-50">Nossa Comunidade</span>
                                 </div>
                             </div>
                             <div class="absolute -bottom-6 -right-6 w-32 h-32 bg-curumim-yellow rounded-3xl -z-10 rotate-12"></div>
                        </div>

                        <div class="space-y-8 order-1 lg:order-2">
                            <h2 class="text-4xl md:text-6xl font-black text-slate-800 leading-tight">
                                Quem <span class="text-curumim-red">somos</span>
                            </h2>
                            <p class="text-xl text-slate-600 leading-relaxed font-medium">
                                Oficina Curumim é uma organização sem fins lucrativos com a missão de estimular o uso da Língua Portuguesa oral e escrita, bem como valorizar o contato com a cultura brasileira para famílias brasileiras da grande Vancouver. 
                            </p>
                            <p class="text-lg text-slate-500 leading-relaxed">
                                Os aspectos culturais, artísticos e sociais da cultura brasileira são utilizados como contexto para o desenvolvimento das propostas nas turmas.
                            </p>
                            <div>
                                <a href={withBase('about')} class="inline-flex items-center gap-3 px-8 py-4 bg-slate-900 text-white font-black rounded-2xl hover:bg-curumim-red transition-all shadow-lg hover:shadow-curumim-red/20 active:scale-95">
                                    Saiba mais
                                    <ArrowRight class="w-5 h-5" />
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {/* Nossas turmas Preview */}
        <section class="py-24 relative">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="glass-card rounded-[3rem] p-12 md:p-20 text-center space-y-10 border border-white/50 shadow-xl relative overflow-hidden">
                    <div class="space-y-4">
                        <h2 class="text-4xl md:text-6xl font-black text-slate-800">
                            Nossas <span class="text-curumim-cyan">turmas</span>
                        </h2>
                        <p class="text-xl text-slate-600 leading-relaxed max-w-3xl mx-auto font-medium">
                            Temos turmas de crianças a partir de 6 meses até 12 anos de idade. Conheça as atividades e propostas de cada uma.
                        </p>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                         {[1, 2, 3].map(() => (
                            <div class="glass-card p-8 rounded-3xl border border-white/60 shadow-sm hover:shadow-md transition-all hover:-translate-y-1 text-left space-y-4">
                                <div class="w-12 h-12 bg-curumim-cyan/20 rounded-2xl flex items-center justify-center">
                                    <Users class="w-6 h-6 text-curumim-cyan" />
                                </div>
                                <h3 class="text-xl font-black text-slate-800">Desenvolvimento Coletivo</h3>
                                <p class="text-slate-500 text-sm">Atividades pensadas para cada faixa etária, respeitando o tempo de cada criança.</p>
                            </div>
                         ))}
                    </div>

                    <div class="pt-4">
                        <a href={withBase('classes')} class="inline-flex items-center gap-3 px-10 py-5 bg-curumim-cyan hover:bg-curumim-green text-white font-black rounded-2xl transition-all shadow-lg shadow-curumim-cyan/20 active:scale-95">
                            Ver todas as turmas
                            <ArrowRight class="w-6 h-6" />
                        </a>
                    </div>
                </div>
            </div>
        </section>

		{/* Schedule & Location */}
		<section class="py-24">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
					<div class="glass-card p-10 rounded-[2.5rem] border border-white/50 shadow-xl space-y-8 flex flex-col justify-between group">
                        <div class="space-y-6">
                            <div class="w-16 h-16 bg-curumim-red/10 rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform duration-500">
                                <Calendar class="w-8 h-8 text-curumim-red" />
                            </div>
                            <div class="space-y-2">
                                <h2 class="text-3xl font-black text-slate-800">Horário</h2>
                                <p class="text-xl text-slate-600 font-bold">
                                    Domingos das 10:00am às 12:00pm
                                </p>
                            </div>
                            <p class="text-slate-400 text-sm ">
                                (Não há aula em finais de semana prolongados dos feriados canadenses)
                            </p>
                        </div>
					</div>

					<div class="glass-card p-10 rounded-[2.5rem] border border-white/50 shadow-xl space-y-8 flex flex-col justify-between group">
                        <div class="space-y-6">
                            <div class="w-16 h-16 bg-curumim-green/10 rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform duration-500">
                                <MapPin class="w-8 h-8 text-curumim-green" />
                            </div>
                            <div class="space-y-2">
                                <h2 class="text-3xl font-black text-slate-800">Localização</h2>
                                <p class="text-xl font-bold text-slate-600 leading-snug">Mount Pleasant Neighbourhood House</p>
                            </div>
                            <a href="https://www.google.com/maps/place/Mount+Pleasant+Neighbourhood+House/@49.2623148,-123.0891644,17z" target="_blank" rel="noopener noreferrer" 
                               class="inline-flex items-center gap-2 text-lg text-curumim-cyan hover:text-curumim-green underline font-bold transition-all decoration-2 underline-offset-4">
                                800 E Broadway, Vancouver, BC
                                <ArrowRight class="w-4 h-4" />
                            </a>
                        </div>
					</div>
				</div>
			</div>
		</section>

		{/* Library Section */}
		<section class="py-24 relative overflow-hidden">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="glass-card rounded-[3rem] p-8 md:p-16 border border-white/50 shadow-2xl">
					<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
						<div class="space-y-8">
							<h2 class="text-4xl md:text-6xl font-black text-slate-800 leading-tight">
								Nossa <span class="text-curumim-purple">biblioteca</span>
							</h2>
							<p class="text-lg text-slate-600 leading-relaxed font-medium">
								As famílias são voluntárias para a organização, catalogação, empréstimos e conferência do acervo. A criança é incentivada a escolher um livro por semana e fazer a leitura com a família em casa.
							</p>
							<div class="bg-gradient-to-r from-curumim-yellow/20 to-curumim-orange/20 rounded-[2rem] p-8 border border-white shadow-inner">
                                <div class="flex items-center gap-6">
                                    <div class="w-16 h-16 bg-white rounded-2xl flex items-center justify-center shadow-sm">
                                        <BookOpen class="w-8 h-8 text-curumim-orange" />
                                    </div>
                                    <div>
                                        <p class="text-3xl md:text-4xl font-black text-slate-800">
                                            + de 1.000
                                        </p>
                                        <p class="text-slate-600 font-bold uppercase tracking-widest text-sm">títulos infantis!</p>
                                    </div>
                                </div>
							</div>
						</div>

<div class="relative">
                             <div class="aspect-square glass-card rounded-[2.5rem] border border-white/60 flex items-center justify-center relative overflow-hidden shadow-xl group">
                                 <Image 
                                    src={randomBibliotecaImg} 
                                    alt="Library"
                                    loading="eager" 
                                    widths={[400, 800, 1200, bibliotecaImages[0].width]} 
                                    sizes="(max-width: 640px) 400px, (max-width: 1024px) 800px, 1200px"
                                    class="biblioteca-img group-hover:scale-110 transition duration-700"
                                 />
                                 <div class="absolute inset-0 bg-gradient-to-br from-curumim-purple/5 to-transparent"></div>
                             </div>
						</div>
					</div>
				</div>
			</div>
		</section>

        {/* Action Sections Grid */}
        <section class="py-24">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    {/* Eventos */}
                    <div class="glass-card rounded-[2.5rem] p-10 md:p-16 border border-white/50 shadow-xl space-y-8 group relative overflow-hidden">
                        <h2 class="text-4xl md:text-5xl font-black text-slate-800 leading-tight">
                            Eventos <span class="text-curumim-red">culturais</span>
                        </h2>
                        <p class="text-lg text-slate-600 font-medium">
                            Temos eventos culturais durante o ano todo na Oficina Curumim. Confira nosso calendário anual.
                        </p>
                        <div>
                            <a href={withBase('events')} class="inline-flex items-center gap-3 px-8 py-4 bg-curumim-red text-white font-black rounded-2xl hover:bg-curumim-purple transition-all shadow-lg hover:shadow-curumim-red/20 active:scale-95">
                                Calendário anual
                                <ArrowRight class="w-5 h-5" />
                            </a>
                        </div>
                    </div>

                    {/* Trabalho */}
                    <div class="glass-card rounded-[2.5rem] p-10 md:p-16 border border-white/50 shadow-xl space-y-8 group relative overflow-hidden">
                        <h2 class="text-4xl md:text-5xl font-black text-slate-800 leading-tight">
                            Quer trabalhar <span class="text-curumim-green">conosco?</span>
                        </h2>
                        <p class="text-lg text-slate-600 font-medium">
                            Estamos sempre buscando voluntários e parceiros apaixonados por educação e cultura.
                        </p>
                        <div>
                            <a href={withBase('jobs')} class="inline-flex items-center gap-3 px-8 py-4 bg-curumim-green text-white font-black rounded-2xl hover:bg-curumim-cyan transition-all shadow-lg hover:shadow-curumim-green/20 active:scale-95">
                                Faça parte da equipe
                                <ArrowRight class="w-5 h-5" />
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
	</main>
</Layout>
