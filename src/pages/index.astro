---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import { useTranslations } from '../utils/i18n';

const t = useTranslations('pt-BR');
---

<Layout title="Oficina Curumim - Português e Cultura Brasileira">
	<Header />
	<main class="pt-24">
		{/* Hero Section with Colorful Background */}
		<section class="relative bg-gradient-to-br from-[#2ccdff] via-[#32bf6e] to-[#fbcd00] overflow-hidden min-h-[80vh] flex items-center justify-center">
            {/* Decorative circles */}
            <div class="absolute top-20 left-10 w-32 h-32 bg-[#ea1f4b] rounded-full opacity-20 blur-2xl"></div>
            <div class="absolute bottom-20 right-10 w-40 h-40 bg-[#ed8300] rounded-full opacity-20 blur-2xl"></div>
            <div class="absolute top-1/2 left-1/4 w-24 h-24 bg-[#8a00aa] rounded-full opacity-20 blur-2xl"></div>
            
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative text-center py-20 z-10">
                <div class="bg-white/10 backdrop-blur-sm rounded-3xl p-8 md:p-12 shadow-2xl">
                    <h1 class="text-5xl md:text-7xl font-black text-white mb-6 leading-tight drop-shadow-lg">
                        No coração de Vancouver.
                    </h1>
                    <h2 class="text-4xl md:text-6xl font-black text-white mb-8">
                        E com o <span class="text-[#fbcd00] drop-shadow-lg">BRASIL</span> no coração.
                    </h2>
                    <a href="/classes" class="inline-block px-12 py-5 bg-white text-[#32bf6e] font-black text-xl rounded-full hover:bg-[#fbcd00] hover:text-white hover:scale-110 transition-all duration-300 shadow-2xl hover:shadow-[#fbcd00]/50">
                        Conheça nossas turmas
                    </a>
                </div>
			</div>
		</section>
        
        {/* Quem somos Section - Image Placeholder Style */}
        <section class="py-20 bg-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center max-w-6xl mx-auto">
                    {/* Image Placeholder */}
                    <div class="relative">
                        <div class="aspect-square bg-gradient-to-br from-[#fbcd00] via-[#ed8300] to-[#ea1f4b] rounded-3xl shadow-2xl transform hover:scale-105 transition-transform duration-500"></div>
                        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent rounded-3xl"></div>
                    </div>

                    {/* Content */}
                    <div class="space-y-6">
                        <h2 class="text-4xl md:text-5xl font-black text-[#ea1f4b]">
                            Quem somos
                        </h2>
                        <p class="text-xl text-slate-700 leading-relaxed">
                            Oficina Curumim é uma organização sem fins lucrativos com a missão de estimular o uso da Língua Portuguesa oral e escrita, bem como valorizar o contato com a cultura brasileira para famílias brasileiras da grande Vancouver. Os aspectos culturais, artísticos e sociais da cultura brasileira são utilizados como contexto para o desenvolvimento das propostas nas turmas.
                        </p>
                        <div>
                            <a href="/about" class="inline-block px-8 py-3 bg-[#ea1f4b] text-white font-black text-lg rounded-full hover:bg-[#8a00aa] transition-colors duration-300">
                                Saiba mais →
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {/* Nossas turmas Preview - Clean Style */}
        <section class="py-20 bg-slate-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-12">
                    <h2 class="text-4xl md:text-5xl font-black text-[#2ccdff] mb-6">
                        Nossas turmas
                    </h2>
                    <p class="text-xl text-slate-700 leading-relaxed max-w-3xl mx-auto mb-8">
                        Temos turmas de crianças a partir de 6 meses até 12 anos de idade. Conheça as atividades e propostas de cada uma.
                    </p>
                    <a href="/classes" class="inline-block px-8 py-3 bg-[#2ccdff] text-white font-black text-lg rounded-full hover:bg-[#32bf6e] transition-colors duration-300">
                        Saiba mais →
                    </a>
                </div>
            </div>
        </section>

		{/* Schedule & Location - Image Placeholder Style */}
		<section class="py-20 bg-slate-50">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-6xl mx-auto">
					<div class="flex flex-col md:flex-row gap-8 items-center">
						{/* Image Placeholder */}
						<div class="relative flex-shrink-0">
							<div class="w-48 h-48 bg-gradient-to-br from-[#fbcd00] via-[#ed8300] to-[#ea1f4b] rounded-3xl shadow-2xl transform hover:scale-105 transition-transform duration-500"></div>
							<div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent rounded-3xl"></div>
						</div>

						{/* Content */}
						<div class="space-y-4">
							<h2 class="text-3xl font-black text-[#ea1f4b]">Horário</h2>
							<p class="text-xl text-slate-700 font-bold">
								Domingos das 10:00am às 12:00pm
							</p>
							<p class="text-slate-600 text-sm">
								(Não há aula em finais de semana prolongados dos feriados canadenses)
							</p>
						</div>
					</div>

					<div class="flex flex-col md:flex-row gap-8 items-center">
						{/* Image Placeholder */}
						<div class="relative flex-shrink-0">
							<div class="w-48 h-48 bg-gradient-to-br from-[#2ccdff] via-[#32bf6e] to-[#8a00aa] rounded-3xl shadow-2xl transform hover:scale-105 transition-transform duration-500"></div>
							<div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent rounded-3xl"></div>
						</div>

						{/* Content */}
						<div class="space-y-4">
							<h2 class="text-3xl font-black text-[#32bf6e]">Localização</h2>
							<p class="text-lg font-bold text-slate-700">Mount Pleasant Neighbourhood House</p>
							<a href="https://www.google.com/maps/place/Mount+Pleasant+Neighbourhood+House/@49.2623148,-123.0891644,17z" target="_blank" rel="noopener noreferrer" class="inline-block text-lg text-[#2ccdff] hover:text-[#32bf6e] underline font-semibold transition-colors">
								800 E Broadway, Vancouver, BC V5T 1Y1
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		{/* Library Section - Image Placeholder Style */}
		<section class="py-20 bg-white">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center max-w-6xl mx-auto">
					{/* Content */}
					<div class="space-y-6">
						<h2 class="text-4xl md:text-5xl font-black text-[#8a00aa]">
							Nossa biblioteca
						</h2>
						<p class="text-lg text-slate-700 leading-relaxed">
							As famílias são voluntárias para a organização, catalogação, empréstimos e conferência do acervo. A criança é incentivada a escolher um livro por semana e fazer a leitura com a família em casa. As famílias também podem escolher um título.
						</p>
						<p class="text-lg text-slate-700 leading-relaxed">
							A leitura de livros, em português, é importante para a manutenção e estímulo do idioma.
						</p>
						<div class="bg-gradient-to-r from-[#fbcd00] to-[#ed8300] rounded-2xl p-6 shadow-lg inline-block">
							<p class="text-2xl md:text-3xl font-black text-white text-center">
								+ de 1000 títulos infantis!
							</p>
						</div>
					</div>

					{/* Image Placeholder */}
					<div class="relative">
						<div class="aspect-square bg-gradient-to-br from-[#8a00aa] via-[#ea1f4b] to-[#32bf6e] rounded-3xl shadow-2xl transform hover:scale-105 transition-transform duration-500"></div>
						<div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent rounded-3xl"></div>
					</div>
				</div>
			</div>
		</section>

        {/* Eventos culturais Preview - Image Placeholder Style */}
        <section class="py-20 bg-slate-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center max-w-6xl mx-auto">
                    {/* Image Placeholder */}
                    <div class="relative">
                        <div class="aspect-square bg-gradient-to-br from-[#ea1f4b] via-[#8a00aa] to-[#fbcd00] rounded-3xl shadow-2xl transform hover:scale-105 transition-transform duration-500"></div>
                        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent rounded-3xl"></div>
                    </div>

                    {/* Content */}
                    <div class="space-y-6">
                        <h2 class="text-4xl md:text-5xl font-black text-[#ea1f4b]">
                            Eventos culturais
                        </h2>
                        <p class="text-xl text-slate-700 leading-relaxed">
                            Temos eventos culturais durante o ano todo na Oficina Curumim. Confira nosso calendário anual e não fique fora de nenhum deles.
                        </p>
                        <div>
                            <a href="/events" class="inline-block px-8 py-3 bg-[#ea1f4b] text-white font-black text-lg rounded-full hover:bg-[#8a00aa] transition-colors duration-300">
                                Calendário anual →
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {/* Quer trabalhar conosco - Image Placeholder Style */}
        <section class="py-20 bg-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center max-w-6xl mx-auto">
                    {/* Content */}
                    <div class="space-y-6">
                        <h2 class="text-4xl md:text-5xl font-black text-[#32bf6e]">
                            Quer trabalhar conosco?
                        </h2>
                        <p class="text-xl text-slate-700 leading-relaxed">
                            Estamos sempre buscando voluntários e parceiros. Clique e saiba como fazer parte da nossa equipe.
                        </p>
                        <div>
                            <a href="/jobs" class="inline-block px-8 py-3 bg-[#32bf6e] text-white font-black text-lg rounded-full hover:bg-[#2ccdff] transition-colors duration-300">
                                Trabalhe com a gente →
                            </a>
                        </div>
                    </div>

                    {/* Image Placeholder */}
                    <div class="relative">
                        <div class="aspect-square bg-gradient-to-br from-[#32bf6e] via-[#2ccdff] to-[#fbcd00] rounded-3xl shadow-2xl transform hover:scale-105 transition-transform duration-500"></div>
                        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent rounded-3xl"></div>
                    </div>
                </div>
            </div>
        </section>
	</main>

    {/* Footer - Vibrant and Fun */}
    <footer class="bg-gradient-to-br from-slate-800 via-slate-900 to-black text-white relative overflow-hidden">
        {/* Decorative elements */}
        <div class="absolute top-0 right-0 w-64 h-64 bg-[#fbcd00] rounded-full opacity-10 blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-[#32bf6e] rounded-full opacity-10 blur-3xl"></div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 relative z-10">
            {/* Logo */}
            <div class="text-center mb-8">
                <img src="/logo.svg" alt="Oficina Curumim" class="h-20 mx-auto mb-6" />
            </div>

            {/* Footer Navigation */}
            <nav class="mb-8">
                <ul class="flex flex-wrap justify-center gap-6 text-sm">
                    <li><a href="/" class="hover:text-[#fbcd00] transition-colors font-semibold">Início</a></li>
                    <li><a href="/about" class="hover:text-[#fbcd00] transition-colors font-semibold">Sobre nós</a></li>
                    <li><a href="/classes" class="hover:text-[#fbcd00] transition-colors font-semibold">Nossas turmas</a></li>
                    <li><a href="/events" class="hover:text-[#fbcd00] transition-colors font-semibold">Eventos culturais</a></li>
                    <li><a href="/jobs" class="hover:text-[#fbcd00] transition-colors font-semibold">Trabalhe com a gente</a></li>
                    <li><a href="/partnerships" class="hover:text-[#fbcd00] transition-colors font-semibold">Parcerias</a></li>
                    <li><a href="/contact" class="hover:text-[#fbcd00] transition-colors font-semibold">Contato</a></li>
                </ul>
            </nav>

            {/* Social Media */}
            <div class="flex justify-center gap-6 mb-8">
                <a href="https://www.instagram.com/oficinacurumim/" target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-gradient-to-br from-purple-500 to-pink-500 rounded-full flex items-center justify-center hover:scale-110 transition-transform" aria-label="Instagram">
                    <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"/>
                    </svg>
                </a>
                <a href="https://www.facebook.com/oficinacurumim" target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-700 rounded-full flex items-center justify-center hover:scale-110 transition-transform" aria-label="Facebook">
                    <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
                    </svg>
                </a>
            </div>

            {/* Newsletter Signup */}
            <div class="max-w-md mx-auto mb-10">
                <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6">
                    <h3 class="text-lg font-bold mb-4 text-center text-[#fbcd00]">Quer receber nossas novidades por email?</h3>
                    <form class="flex gap-2">
                        <input 
                            type="email" 
                            placeholder="Seu email" 
                            class="flex-1 px-4 py-3 rounded-full text-slate-900 font-semibold focus:outline-none focus:ring-4 focus:ring-[#fbcd00]/50"
                        />
                        <button 
                            type="submit" 
                            class="px-6 py-3 bg-gradient-to-r from-[#fbcd00] to-[#ed8300] hover:from-[#ed8300] hover:to-[#ea1f4b] rounded-full font-black text-slate-900 hover:text-white transition-all hover:scale-105 shadow-lg"
                        >
                            Cadastre-se!
                        </button>
                    </form>
                </div>
            </div>

            {/* Copyright and Credits */}
            <div class="border-t border-white/20 pt-8 text-center text-sm text-slate-300">
                <p class="mb-2 font-semibold">© 2022 Oficina Curumim.</p>
                <p class="text-slate-400">
                    Photos by <a href="https://sites.google.com/view/portfolioinpictures/home" target="_blank" rel="noopener noreferrer" class="hover:text-[#fbcd00] transition-colors">Maria Tebet</a> | 
                    Rebrand & webdesign by <a href="http://www.brunocirello.com" target="_blank" rel="noopener noreferrer" class="hover:text-[#fbcd00] transition-colors">Bruno Cirello</a>
                </p>
            </div>
        </div>
    </footer>
</Layout>
