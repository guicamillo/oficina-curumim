---
import Layout from '../layouts/Layout.astro';
import PartyPopper from '@lucide/astro/icons/party-popper';
import Calendar from '@lucide/astro/icons/calendar';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import Music from '@lucide/astro/icons/music';
import Users from '@lucide/astro/icons/users';
import Heart from '@lucide/astro/icons/heart';
import Globe from '@lucide/astro/icons/globe';
import Star from '@lucide/astro/icons/star';
import { withBase } from '../utils/paths';
import { getLangFromUrl, useTranslations } from '../utils/i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const events = [
    {
        name: t({ key: 'events.cards.carnival.name', message: 'Carnaval' }),
        date: t({ key: 'events.cards.carnival.date', message: 'Fevereiro/Março' }),
        description: t({ key: 'events.cards.carnival.description', message: 'Atividades lúdicas sobre a história e manifestações culturais das diferentes regiões do Brasil. Organizamos uma grande festa com ritmos, danças e trajes típicos.' }),
        color: "curumim-yellow",
        icom: PartyPopper
    },
    {
        name: t({ key: 'events.cards.plh.name', message: 'PLH' }),
        date: t({ key: 'events.cards.plh.date', message: '16 de Maio' }),
        subtitle: t({ key: 'events.cards.plh.subtitle', message: 'Português como Língua de Herança' }),
        description: t({ key: 'events.cards.plh.description', message: 'Dia de unir as iniciativas de PLH pelo mundo. Realizamos salas temáticas com propostas educativas que reforçam a noção de pertencimento e brasilidade.' }),
        color: "curumim-green",
        icom: Globe
    },
    {
        name: t({ key: 'events.cards.juneParty.name', message: 'Festa Junina' }),
        date: t({ key: 'events.cards.juneParty.date', message: 'Junho' }),
        description: t({ key: 'events.cards.juneParty.description', message: 'Um dos momentos mais esperados! Organizada por famílias e equipe, traz o melhor das tradições de São João para o contexto canadense.' }),
        color: "curumim-orange",
        icom: Music
    },
    {
        name: t({ key: 'events.cards.yearEnd.name', message: 'Festa de Final de Ano' }),
        date: t({ key: 'events.cards.yearEnd.date', message: 'Dezembro' }),
        description: t({ key: 'events.cards.yearEnd.description', message: 'Apresentação especial das crianças para as famílias, celebrando o fechamento do ano com muita música e valorização do nosso idioma.' }),
        color: "curumim-purple",
        icom: Star
    },
    {
        name: t({ key: 'events.cards.birthdays.name', message: 'Aniversários' }),
        date: t({ key: 'events.cards.birthdays.date', message: 'Durante o ano todo' }),
        description: t({ key: 'events.cards.birthdays.description', message: 'Celebramos cada aniversário com parabéns em português e cartões confeccionados pelos amigos, promovendo alegria e interação na turma.' }),
        color: "curumim-red",
        icom: Heart
    },
    {
        name: t({ key: 'events.cards.community.name', message: 'Comunidade Brasileira' }),
        date: t({ key: 'events.cards.community.date', message: 'Eventos abertos' }),
        description: t({ key: 'events.cards.community.description', message: 'Participação em eventos abertos em Vancouver, compartilhando nossas propostas com o público e mantendo vivas nossas tradições.' }),
        color: "curumim-cyan",
        icom: Users
    }
];
---

<Layout title={t({ key: 'events.meta.title', message: 'Eventos Culturais - Oficina Curumim' })}>
    <main>
        {/* Hero Section */}
        <section class="relative pt-32 pb-20 px-4 overflow-hidden">
            <div class="max-w-7xl mx-auto text-center relative z-10">
                <h1 class="text-5xl md:text-8xl font-black text-slate-800 mb-8 tracking-tight">
                    {t({ key: 'events.hero.titlePrefix', message: 'Eventos' })} <span class="text-curumim-red ">{t({ key: 'events.hero.titleAccent', message: 'Culturais' })}</span>
                </h1>
                <p class="text-xl md:text-2xl text-slate-600 font-medium max-w-4xl mx-auto leading-relaxed">
                    {t({ key: 'events.hero.subtitle', message: 'A preservação da nossa cultura através do envolvimento das famílias. Planejamos cada momento para que nossas raízes floresçam em Vancouver.' })}
                </p>
            </div>
            
            {/* Background elements */}
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1000px] h-[600px] bg-curumim-red/5 rounded-full blur-[120px] -z-10"></div>
        </section>

        {/* Events Grid */}
        <section class="py-12 px-4 pb-32">
            <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {events.map((event) => (
                    <div class="group h-full">
                        <div class="glass-card h-full rounded-[2.5rem] p-8 md:p-10 border border-white/60 shadow-xl transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl relative overflow-hidden flex flex-col">
                            <div class={`absolute top-0 right-0 w-32 h-32 bg-${event.color}/10 rounded-full -mr-16 -mt-16 blur-2xl group-hover:bg-${event.color}/20 transition-colors`}></div>
                            
                            <div class="space-y-6 flex-grow">
                                <div class={`w-16 h-16 bg-${event.color}/10 rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform`}>
                                    <event.icom class={`w-8 h-8 text-${event.color}`} />
                                </div>
                                
                                <div class="space-y-2">
                                    <div class="flex items-center justify-between">
                                        <h2 class="text-2xl font-black text-slate-800">{event.name}</h2>
                                    </div>
                                    <div class="inline-flex items-center gap-2 text-sm font-bold text-slate-400 uppercase tracking-widest">
                                        <Calendar class="w-4 h-4" />
                                        {event.date}
                                    </div>
                                    {event.subtitle && (
                                        <p class={`text-xs font-bold text-${event.color} `}>{event.subtitle}</p>
                                    )}
                                </div>

                                <p class="text-slate-600 font-medium leading-relaxed">
                                    {event.description}
                                </p>
                            </div>

                            <div class="pt-8">
                                <a href={withBase('contact')} class={`w-full py-4 rounded-2xl border-2 border-${event.color}/20 flex items-center justify-center gap-2 font-black text-slate-700 hover:bg-${event.color} hover:text-white transition-all`}>
                                    {t({ key: 'events.cards.cta', message: 'Saiba mais' })}
                                    <ArrowRight class="w-4 h-4" />
                                </a>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        {/* Final CTA */}
        <section class="py-32 px-4 relative overflow-hidden">
             <div class="absolute -z-10 top-0 left-0 w-full h-full bg-curumim-red/5 skew-y-3"></div>
            <div class="max-w-5xl mx-auto">
                <div class="glass-card rounded-[4rem] p-12 md:p-24 text-center space-y-10 border border-white/60 shadow-2xl relative overflow-hidden group">
                    <div class="absolute -top-20 -right-20 w-96 h-96 bg-curumim-yellow/10 rounded-full blur-[100px] -z-10 group-hover:bg-curumim-yellow/20 transition-colors duration-1000"></div>
                    
                    <div class="space-y-6 relative z-10">
                        <p class="text-curumim-red font-black text-xl uppercase tracking-widest animate-pulse">{t({ key: 'events.cta.badge', message: '- Participe -' })}</p>
                        <h2 class="text-4xl md:text-7xl font-black text-slate-800 leading-tight">
                            {t({ key: 'events.cta.titlePrefix', message: 'Não perca nenhum' })} <span class="text-curumim-red">{t({ key: 'events.cta.titleAccent', message: 'evento cultural!' })}</span>
                        </h2>
                        <p class="text-slate-500 text-lg md:text-xl max-w-2xl mx-auto font-medium">
                            {t({ key: 'events.cta.body', message: 'Nossa comunidade é vibrante e acolhedora. Venha vivenciar o Brasil em Vancouver com a gente.' })}
                        </p>
                    </div>

                    <div class="pt-8 relative z-10">
                        <a href={withBase('contact')} class="inline-flex items-center gap-4 px-12 py-6 bg-curumim-red hover:bg-curumim-purple text-white font-black text-2xl rounded-[2rem] transition-all hover:scale-110 active:scale-95 shadow-2xl shadow-curumim-red/20">
                            {t({ key: 'events.cta.button', message: 'Quero me envolver' })}
                            <ArrowRight class="w-8 h-8" />
                        </a>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>
