---
import '../styles/global.css';
import { getLangFromUrl } from '../utils/i18n';



interface Props {
	title: string;
    description?: string;
}

const { title, description = "Oficina Curumim - Português e Cultura Brasileira em Vancouver" } = Astro.props;
const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
    
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/selo.png" />
		<meta name="generator" content={Astro.generator} />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body class="bg-white text-slate-900 antialiased flex flex-col min-h-screen">
		<div class="flex-grow">
			<slot />
		</div>
		<footer class="bg-gradient-to-br from-slate-800 via-slate-900 to-black text-white">
    <!-- Decorative elements -->
    <div class="absolute top-0 right-0 w-64 h-64 bg-[#fbcd00] rounded-full opacity-10 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-[#32bf6e] rounded-full opacity-10 blur-3xl"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 relative z-10">
        <!-- Logo -->
        <div class="text-center mb-8">
            <img src="/logo.svg" alt="Oficina Curumim" class="h-20 mx-auto mb-6" />
        </div>

        <!-- Footer Navigation -->
        <nav class="mb-8">
            <ul class="flex flex-wrap justify-center gap-6 text-sm">
                <li><a href="/" class="hover:text-[#fbcd00] transition-colors font-semibold">Início</a></li>
                <li><a href="/about" class="hover:text-[#fbcd00] transition-colors font-semibold">Sobre nós</a></li>
                <li><a href="/classes" class="hover:text-[#fbcd00] transition-colors font-semibold">Nossas turmas</a></li>
                <li><a href="/events" class="hover:text-[#fbcd00] transition-colors font-semibold">Eventos culturais</a></li>
                <li><a href="/jobs" class="hover:text-[#fbcd00] transition-colors font-semibold">Trabalhe com a gente</a></li>
                <li><a href="/partnerships" class="hover:text-[#fbcd00] transition-colors font-semibold">Parcerias</a></li>
                <li><a href="/contact" class="hover:text-[#fbcd00] transition-colors font-semibold">Contato</a></li>
            </ul>
        </nav>

        <!-- Social Media -->
        <div class="flex justify-center gap-6 mb-8">
            <a href="https://www.instagram.com/oficinacurumim/" target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-gradient-to-br from-purple-500 to-pink-500 rounded-full flex items-center justify-center hover:scale-110 transition-transform" aria-label="Instagram">
                <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"/>
                </svg>
            </a>
            <a href="https://www.facebook.com/oficinacurumim" target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-700 rounded-full flex items-center justify-center hover:scale-110 transition-transform" aria-label="Facebook">
                <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
                </svg>
            </a>
        </div>

        <!-- Newsletter Signup -->
        <div class="max-w-md mx-auto mb-10">
            <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6">
                <h3 class="text-lg font-bold mb-4 text-center text-[#fbcd00]">Quer receber nossas novidades por email?</h3>
                <form class="flex gap-2">
                    <input 
                        type="email" 
                        placeholder="Seu email" 
                        class="flex-1 px-4 py-3 rounded-full text-slate-900 font-semibold focus:outline-none focus:ring-4 focus:ring-[#fbcd00]/50"
                    />
                    <button 
                        type="submit" 
                        class="px-6 py-3 bg-gradient-to-r from-[#fbcd00] to-[#ed8300] hover:from-[#ed8300] hover:to-[#ea1f4b] rounded-full font-black text-slate-900 hover:text-white transition-all hover:scale-105 shadow-lg"
                    >
                        Cadastre-se!
                    </button>
                </form>
            </div>
        </div>

        <!-- Copyright and Credits -->
        <div class="border-t border-white/20 pt-8 text-center text-sm text-slate-300">
            <p class="mb-2 font-semibold">© 2022 Oficina Curumim.</p>
            <p class="text-slate-400">
                Fotos por <a href="https://sites.google.com/view/portfolioinpictures/home" target="_blank" rel="noopener noreferrer" class="hover:text-[#fbcd00] transition-colors">Maria Tebet</a> | 
                Branding por <a href="http://www.brunocirello.com" target="_blank" rel="noopener noreferrer" class="hover:text-[#fbcd00] transition-colors">Bruno Cirello</a> | 
                Website por <a href="http://www.guilhermecamillo.com.br" target="_blank" rel="noopener noreferrer" class="hover:text-[#fbcd00] transition-colors">Guilherme Camillo</a> 
            </p>
        </div>
    </div>
</footer>

	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
