---
import '../styles/global.css';
import { getLangFromUrl } from '../utils/i18n';



interface Props {
	title: string;
    description?: string;
}

const { title, description = "Oficina Curumim - Português e Cultura Brasileira em Vancouver" } = Astro.props;
const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
    
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/selo.png" />
		<meta name="generator" content={Astro.generator} />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body class="bg-white text-slate-900 antialiased flex flex-col min-h-screen">
		<div class="flex-grow">
			<slot />
		</div>
		<footer class="bg-gradient-to-br from-slate-800 via-slate-900 to-black text-white">
    <!-- Decorative elements -->
    <div class="absolute top-0 right-0 w-64 h-64 bg-[#fbcd00] rounded-full opacity-10 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-[#32bf6e] rounded-full opacity-10 blur-3xl"></div>
    
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-12">
                <!-- Left Column: Brand & Social -->
                <div class="flex flex-col items-center lg:items-start space-y-8">
                    <!-- Logo -->
                    <img src="/logo.svg" alt="Oficina Curumim" class="h-24 w-auto" />
                    
                    <!-- Social Media -->
                    <div class="flex gap-4">
                        <a href="https://www.instagram.com/oficinacurumim/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white/10 hover:bg-[#fbcd00] rounded-full flex items-center justify-center transition-all hover:scale-110 group" aria-label="Instagram">
                            <svg class="w-5 h-5 text-white group-hover:text-slate-900" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"/>
                            </svg>
                        </a>
                        <a href="https://www.facebook.com/oficinacurumim" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white/10 hover:bg-[#fbcd00] rounded-full flex items-center justify-center transition-all hover:scale-110 group" aria-label="Facebook">
                            <svg class="w-5 h-5 text-white group-hover:text-slate-900" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
                            </svg>
                        </a>
                    </div>

                    <div class="text-white/60 text-sm text-center lg:text-left">
                        <p>© 2022 Oficina Curumim.</p>
                        <p class="mt-2">
                            Website desenvolvido por <a href="http://www.guilhermecamillo.com.br" target="_blank" class="text-white hover:text-[#fbcd00] transition-colors">Guilherme Camillo</a>
                        </p>
                    </div>
                </div>

                <!-- Right Column: Navigation & Newsletter -->
                <div class="space-y-8">
                    <!-- Navigation Grid -->
                    <nav>
                        <ul class="grid grid-cols-2 sm:grid-cols-3 gap-4 text-sm">
                            <li><a href="/" class="text-white/80 hover:text-[#fbcd00] transition-colors font-medium">Início</a></li>
                            <li><a href="/about" class="text-white/80 hover:text-[#fbcd00] transition-colors font-medium">Sobre nós</a></li>
                            <li><a href="/classes" class="text-white/80 hover:text-[#fbcd00] transition-colors font-medium">Nossas turmas</a></li>
                            <li><a href="/events" class="text-white/80 hover:text-[#fbcd00] transition-colors font-medium">Eventos culturais</a></li>
                            <li><a href="/jobs" class="text-white/80 hover:text-[#fbcd00] transition-colors font-medium">Trabalhe com a gente</a></li>
                            <li><a href="/partnerships" class="text-white/80 hover:text-[#fbcd00] transition-colors font-medium">Parcerias</a></li>
                            <li><a href="/contact" class="text-white/80 hover:text-[#fbcd00] transition-colors font-medium">Contato</a></li>
                        </ul>
                    </nav>

                    <!-- Newsletter Component -->
                    <div class="bg-white/5 backdrop-blur-sm rounded-xl p-6 border border-white/10">
                        <h3 class="text-base font-bold mb-3 text-[#fbcd00]">Fique por dentro das novidades</h3>
                        <form class="flex flex-col sm:flex-row gap-2">
                            <input 
                                type="email" 
                                placeholder="Seu email de contato" 
                                class="flex-1 px-4 py-2.5 rounded-lg bg-white/10 border border-white/10 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-[#fbcd00] text-sm"
                            />
                            <button 
                                type="submit" 
                                class="px-6 py-2.5 bg-[#fbcd00] hover:bg-[#ed8300] rounded-lg font-bold text-slate-900 transition-all hover:scale-105 text-sm whitespace-nowrap"
                            >
                                Inscrever
                            </button>
                        </form>
                    </div>
                </div>
            </div>
            
            <!-- Bottom Bar -->
            <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center text-xs text-white/40">
                <p>Oficina Curumim - Português e Cultura Brasileira</p>
                <div class="flex gap-4 mt-2 md:mt-0">
                    <a href="#" class="hover:text-white transition-colors">Termos de Uso</a>
                    <a href="#" class="hover:text-white transition-colors">Privacidade</a>
                </div>
            </div>
        </div>
    </footer>

	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
