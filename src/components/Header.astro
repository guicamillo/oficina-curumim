---
import {ClientRouter} from "astro:transitions"
import { getLangFromUrl, useTranslations } from '../utils/i18n';
import Menu from '@lucide/astro/icons/menu';
import X from '@lucide/astro/icons/x';
import { base, withBase } from '../utils/paths';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const homeUrl = base;
const aboutUrl = withBase('about');
const classesUrl = withBase('classes');
const eventsUrl = withBase('events');
const contactUrl = withBase('contact');

const navItems = [
  { href: homeUrl, label: t('nav.home') },
  { href: aboutUrl, label: t('nav.about') },
  { href: classesUrl, label: t('nav.classes') },
  { href: eventsUrl, label: t('nav.events') },
  { href: contactUrl, label: t('nav.contact') },
];

const currentPath = Astro.url.pathname;
function isActive(href: string) {
  const normalizedPath = currentPath.endsWith('/') ? currentPath : `${currentPath}/`;
  const normalizedHref = href.endsWith('/') ? href : `${href}/`;
  
  if (href === base || href === `${base}/`) {
    return normalizedPath === normalizedHref;
  }
  return normalizedPath.startsWith(normalizedHref);
}
---

<ClientRouter />
<header id="header" class="glass-header sticky top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20 md:h-24">
      {/* Logo */}
      <div class="flex-shrink-0">
        <a href={homeUrl} class="block transition-transform hover:scale-105 active:scale-95 duration-300">
           <img id="logo" src={withBase('logo.svg')} alt="Oficina Curumim" class="h-12 md:h-16 w-auto" />
        </a>
      </div>
      
      {/* Desktop Navigation */}
      <nav class="hidden md:flex items-center space-x-1">
        {navItems.map((item) => {
          const active = isActive(item.href);
          return (
            <a
              href={item.href}
              class={`px-4 py-2 rounded-xl text-sm font-bold transition-all duration-300 ${
                active
                  ? 'text-curumim-orange bg-curumim-orange/5'
                  : 'text-slate-600 hover:text-curumim-orange hover:bg-slate-50'
              }`}
            >
              {item.label}
            </a>
          );
        })}
      </nav>

      {/* Action Area */}
      <div class="flex items-center gap-4">
          {/* Mobile menu button */}
          <button id="mobile-menu-button" class="md:hidden p-2 rounded-xl hover:bg-slate-100 transition-colors" aria-label="Menu">
            <Menu class="w-6 h-6 text-slate-700" id="menu-icon" />
            <X class="w-6 h-6 text-slate-700 hidden" id="close-icon" />
          </button>
      </div>
    </div>
  </div>

  {/* Mobile Menu */}
  <div id="mobile-menu" class="hidden md:hidden glass-header border-t border-white/20 absolute w-full left-0 animate-in fade-in slide-in-from-top-4 duration-300">
      <nav class="flex flex-col p-4 space-y-2">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`px-4 py-3 rounded-xl text-base font-bold transition-all ${
              isActive(item.href)
                ? 'text-curumim-orange bg-curumim-orange/5'
                : 'text-slate-600 hover:bg-slate-50'
            }`}
          >
            {item.label}
          </a>
        ))}
      </nav>
  </div>
</header>

<script>
    function initMobileMenu() {
        const button = document.getElementById('mobile-menu-button');
        const menu = document.getElementById('mobile-menu');
        const menuIcon = document.getElementById('menu-icon');
        const closeIcon = document.getElementById('close-icon');

        button?.addEventListener('click', () => {
            menu?.classList.toggle('hidden');
            menuIcon?.classList.toggle('hidden');
            closeIcon?.classList.toggle('hidden');
        });

        // Close menu when clicking a link
        const links = menu?.querySelectorAll('a');
        links?.forEach(link => {
            link.addEventListener('click', () => {
                menu?.classList.add('hidden');
                menuIcon?.classList.remove('hidden');
                closeIcon?.classList.add('hidden');
            });
        });
    }

    document.addEventListener('astro:page-load', initMobileMenu);
</script>
