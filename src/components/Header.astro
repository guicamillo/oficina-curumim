---
import { getLangFromUrl, useTranslations } from '../utils/i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const homeUrl = lang === 'pt-BR' ? '/' : '/en-CA';
const aboutUrl = lang === 'pt-BR' ? '/about' : '/en-CA/about';
const classesUrl = lang === 'pt-BR' ? '/classes' : '/en-CA/classes';
const eventsUrl = lang === 'pt-BR' ? '/events' : '/en-CA/events';
const contactUrl = lang === 'pt-BR' ? '/contact' : '/en-CA/contact';

const navItems = [
  { href: homeUrl, label: t('nav.home') },
  { href: aboutUrl, label: t('nav.about') },
  { href: classesUrl, label: t('nav.classes') },
  { href: eventsUrl, label: t('nav.events') },
  { href: contactUrl, label: t('nav.contact') },
];

// Get current path for active state
const currentPath = Astro.url.pathname;

// Function to check if nav item is active
function isActive(href: string) {
  if (href === '/') {
    return currentPath === '/';
  }
  return currentPath.startsWith(href);
}
---

<header id="header" class="bg-white shadow-sm fixed top-0 left-0 right-0 z-50 border-b border-slate-100 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-24">
      {/* Logo */}
      <div class="flex-shrink-0">
        <a href={homeUrl} class="block transition-transform hover:scale-105">
           <img id="logo" src="/logo.svg" alt="Oficina Curumim" class="h-12 sm:h-16 w-auto transition-all duration-300" />
        </a>
      </div>
      
      {/* Desktop Navigation */}
      <nav class="hidden md:flex items-center space-x-8">
        {navItems.map((item) => {
          const active = isActive(item.href);
          return (
            <a
              href={item.href}
              class={`nav-underline px-1 py-2 font-semibold text-base transition-all duration-300 ${
                active
                  ? 'text-slate-900 active'
                  : 'text-slate-700 hover:text-slate-900'
              }`}
            >
              {item.label}
            </a>
          );
        })}
      </nav>

      {/* Language Switcher - Hidden for now, keeping only PT-BR */}
      {/* 
      <div class="hidden md:flex items-center gap-2">
        <a 
          href="/" 
          class={`px-4 py-2 rounded-full font-bold text-sm transition-all duration-300 ${
            lang === 'pt-BR' 
              ? 'bg-gradient-to-r from-[#32bf6e] to-[#2ccdff] text-white shadow-md' 
              : 'bg-slate-100 text-slate-600 hover:bg-slate-200'
          }`}
        >
          PT
        </a>
        <a 
          href="/en-CA" 
          class={`px-4 py-2 rounded-full font-bold text-sm transition-all duration-300 ${
            lang === 'en-CA' 
              ? 'bg-gradient-to-r from-[#32bf6e] to-[#2ccdff] text-white shadow-md' 
              : 'bg-slate-100 text-slate-600 hover:bg-slate-200'
          }`}
        >
          EN
        </a>
      </div>
      */}

      {/* Mobile menu button - Hidden for now */}
      {/*
      <button class="md:hidden p-2 rounded-lg hover:bg-slate-100" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
      */}
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const header = document.getElementById('header') as HTMLElement;
    const logo = document.getElementById('logo') as HTMLImageElement;

    if (header && logo) {
      function handleScroll() {
        if (window.scrollY > 50) {
          header.classList.add('scrolled');
          logo.classList.add('logo-scrolled');
        } else {
          header.classList.remove('scrolled');
          logo.classList.remove('logo-scrolled');
        }
      }

      window.addEventListener('scroll', handleScroll);
    }
  });
</script>
