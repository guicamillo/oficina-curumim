---
import { getLangFromUrl, useTranslations } from '../utils/i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const homeUrl = lang === 'pt-BR' ? '/' : '/en-CA';
const aboutUrl = lang === 'pt-BR' ? '/about' : '/en-CA/about';
const classesUrl = lang === 'pt-BR' ? '/classes' : '/en-CA/classes';
const eventsUrl = lang === 'pt-BR' ? '/events' : '/en-CA/events';
const jobsUrl = lang === 'pt-BR' ? '/jobs' : '/en-CA/jobs';
const partnershipsUrl = lang === 'pt-BR' ? '/partnerships' : '/en-CA/partnerships';
const contactUrl = lang === 'pt-BR' ? '/contact' : '/en-CA/contact';

const navItems = [
  { href: homeUrl, label: t('nav.home') },
  { href: aboutUrl, label: t('nav.about') },
  { href: classesUrl, label: t('nav.classes') },
  { href: eventsUrl, label: t('nav.events') },
  { href: contactUrl, label: t('nav.contact') },
];
---

<header class="bg-white/80 backdrop-blur-md border-b border-slate-100 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-20 items-center">
      <div class="flex-shrink-0 flex items-center">
        <a href={homeUrl} class="text-2xl font-bold text-blue-600 tracking-tight flex items-center gap-2">
           {/* Placeholder for Logo */}
           <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-green-500 rounded-lg"></div>
           Oficina Curumim
        </a>
      </div>
      <nav class="hidden md:flex space-x-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="text-slate-600 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium transition-colors"
          >
            {item.label}
          </a>
        ))}
      </nav>
      <div class="flex items-center space-x-4">
        <div class="text-sm font-medium">
            <a href="/" class={`px-2 py-1 rounded transition-colors ${lang === 'pt-BR' ? 'bg-blue-50 text-blue-600' : 'text-slate-500 hover:text-slate-700'}`}>PT</a>
            <span class="text-slate-300">|</span>
            <a href="/en-CA" class={`px-2 py-1 rounded transition-colors ${lang === 'en-CA' ? 'bg-blue-50 text-blue-600' : 'text-slate-500 hover:text-slate-700'}`}>EN</a>
        </div>
      </div>
    </div>
  </div>
</header>
