#!/usr/bin/env sh
set -eu

bun run i18n:validate
bun run i18n:extract

if ! git diff --quiet -- src/locales/pt-BR/translation.json; then
  echo "Translation catalog changed after extraction. Review and stage src/locales/pt-BR/translation.json before committing."
  exit 1
fi

bun run format:check
bun run lint
